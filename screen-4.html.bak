<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ask: Partner Cloud Setup - Features Discovery</title>
  <link rel="stylesheet" href="v2.css?v=1780526681">
  <link rel="stylesheet" href="screen-3-updated.css">
  <style>
    /* App container */
    .app-container { display: flex; flex-direction: column; height: 100vh; overflow: hidden; background: #ffffff; }

    /* Conversation main area */
    .convo-main { flex: 1; display: flex; flex-direction: column; overflow: hidden; padding-bottom: 48px; background: #ffffff; position: relative; }
    .convo-title-bar { display: flex; align-items: center; padding: 12px 24px; border-bottom: 1px solid #e5e5e5; flex-shrink: 0; background: #ffffff; }
    .convo-title { display: flex; align-items: center; gap: 8px; font-size: 20px; font-weight: 600; color: #001e5b; }
    .convo-thread { flex: 1; overflow-y: auto; padding: 24px 32px 150px; display: flex; flex-direction: column; gap: 20px; max-width: 800px; margin: 0 auto; width: 100%; }

    /* User bubble */
    .user-bubble { display: flex; justify-content: flex-end; }
    .user-bubble p { max-width: 70%; background: #e8f4fd; border-radius: 16px 16px 4px 16px; padding: 12px 18px; font-size: 14px; color: #032e61; line-height: 1.5; margin: 0; }

    /* Agent response */
    .agent-response { display: flex; flex-direction: column; gap: 8px; width: 100%; }
    .agent-header { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .agent-header .sparkle { width: 16px; height: 16px; }
    .agent-header .agent-name { font-size: 13px; font-weight: 600; color: #03234d; }
    .agent-response p { font-size: 14px; color: #001e5b; line-height: 19px; margin: 0; }

    /* Searching animation */
    .search-status { display: flex; align-items: center; gap: 8px; font-size: 12px; color: #2e2e2e; line-height: 17px; padding-left: 12px; }
    .search-status svg { flex-shrink: 0; width: 16px; height: 16px; }
    .search-status-count { margin-left: auto; color: #5c5c5c; font-size: 12px; }

    /* Features list */
    .features-heading { font-size: 15px; font-weight: 700; color: #03234d; margin: 8px 0 4px; }
    .feature-item { margin: 6px 0; }
    .feature-item .feature-name { font-size: 14px; color: #2e2e2e; margin: 0; }
    .feature-item .feature-name--bold { font-weight: 700; }
    .feature-item .feature-desc { font-size: 13px; color: #5c5c5c; margin: 2px 0 0; }

    /* Chat input */
    .convo-input-area { padding: 12px 24px; border-top: none; flex-shrink: 0; display: flex; flex-direction: column; gap: 8px; background: #ffffff; position: absolute; bottom: 0; left: 0; right: 0; max-width: 800px; margin: 0 auto; }
    .convo-input-wrapper { display: flex; flex-direction: column; gap: 4px; }
    .convo-input-box { background: #f3f3f3; border: 1px solid #5c5c5c; border-radius: 8px; overflow: hidden; display: flex; flex-direction: column; }
    .convo-input-text { padding: 12px 16px; background: #ffffff; border: none; outline: none; font-size: 14px; font-family: var(--v2-font); color: #5c5c5c; min-height: 43px; resize: none; }
    .convo-input-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; background: #ffffff; border-top: 1px solid #f3f3f3; }
    .convo-input-actions { display: flex; gap: 8px; }
    .input-action-btn { background: none; border: none; cursor: pointer; padding: 0; display: flex; align-items: center; width: 16px; height: 16px; color: #706e6b; }
    .input-action-btn:hover { color: #181818; }

    /* Connections bar */
    .convo-connections-bar { display: flex; align-items: center; gap: 8px; padding: 8px 0; font-size: 10px; color: #2e2e2e; flex-shrink: 0; }
    .connections-label { font-weight: 500; }
    .connection-icon { width: 16px; height: 16px; border-radius: 4px; border: 1px solid #e5e5e5; background: #ffffff; display: flex; align-items: center; justify-content: center; margin-right: -4px; }
    .connection-icon svg { width: 12px; height: 12px; }
    .connections-more { color: #0176D3; text-decoration: none; font-size: 10px; }
    .convo-disclaimer { margin-left: auto; font-size: 10px; color: #5c5c5c; text-align: center; }
    .feedback-link { color: #0176D3; text-decoration: none; font-size: 10px; }

    /* Animations */
    @keyframes fadeSlideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes bounceDot { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }

    .animate-in { animation: fadeSlideUp 0.5s ease forwards; }
    .delay-1 { animation-delay: 0.3s; opacity: 0; }
    .delay-2 { animation-delay: 0.8s; opacity: 0; }
    .delay-3 { animation-delay: 1.3s; opacity: 0; }
    .delay-4 { animation-delay: 1.8s; opacity: 0; }

    /* Thinking dots */
    .thinking-dots { display: inline-flex; gap: 4px; padding: 8px 0; }
    .thinking-dots span { width: 8px; height: 8px; background: #0176D3; border-radius: 50%; display: inline-block; animation: bounceDot 1.4s infinite ease-in-out both; }
    .thinking-dots span:nth-child(1) { animation-delay: -0.32s; }
    .thinking-dots span:nth-child(2) { animation-delay: -0.16s; }
    .thinking-dots span:nth-child(3) { animation-delay: 0s; }
    .thinking-dots-container { animation: fadeSlideUp 0.3s ease forwards; }
    .thinking-dots-container.hide { display: none; }

    /* Agent response reveal */
    .agent-content { opacity: 0; animation: fadeSlideUp 0.5s ease forwards; animation-delay: 2.2s; }

    /* Search ask container */
    .search-ask-container { display: flex; align-items: center; gap: 8px; }
    .ask-button { display: inline-flex; align-items: center; gap: 4px; height: 32px; padding: 0 12px; background: #f3f3f3; border: 1px solid #d8d8d8; border-radius: 9999px; font-size: 13px; font-weight: 500; color: #0176D3; cursor: pointer; font-family: inherit; }
    .ask-button:hover { background: #edf4ff; }

    /* Split button */
    .split-button { display: flex; align-items: center; }
    .split-btn-main { display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: none; border: none; cursor: pointer; border-radius: 4px 0 0 4px; }
    .split-btn-dropdown { display: flex; align-items: center; justify-content: center; width: 20px; height: 28px; background: none; border: none; cursor: pointer; border-radius: 0 4px 4px 0; }
    .split-btn-main:hover, .split-btn-dropdown:hover { background: #f3f3f3; }

    /* App name in nav */
    .app-name { display: flex; align-items: center; gap: 8px; padding: 0 12px; height: 100%; }
    .app-name-text { font-size: 14px; font-weight: 600; color: #03234d; }
    .waffle-icon { display: flex; align-items: center; justify-content: center; width: 24px; height: 24px; background: none; border: none; cursor: pointer; }

    /* Footer override for ask pages */
    .global-footer--ask { left: 0; }
  </style>
</head>
<body>
  <div class="app-container">
    <!-- Global Header -->
    <header class="global-header">
      <div class="header-left">
        <div class="sf-logo"><svg viewBox="0 0 61 42" width="61" height="42" xmlns="http://www.w3.org/2000/svg"><path d="M25.5 5.3c2.7-2.8 6.4-4.5 10.5-4.5 5.5 0 10.3 3.1 12.8 7.7 2.2-1 4.6-1.5 7.2-1.5 9.7 0 17.5 7.8 17.5 17.5S65.7 42 56 42c-1.5 0-3-.2-4.4-.6-2.2 3.7-6.2 6.2-10.8 6.2-2.2 0-4.3-.6-6.1-1.6-2.3 4.4-6.9 7.5-12.2 7.5-5.1 0-9.6-2.8-12-7-1.3.4-2.7.6-4.1.6C2.9 47.1-1 43.2-1 38.4c0-3.1 1.6-5.8 4.1-7.4-.6-1.5-1-3.2-1-4.9 0-7.6 6.2-13.8 13.8-13.8 3.2 0 6.1 1.1 8.5 2.9" transform="translate(1 -0.8) scale(0.85)" fill="#00A1E0"/></svg></div>
      </div>
      <div class="header-center">
        <div class="search-ask-container">
          <div class="search-input-wrapper"><svg class="search-icon" width="16" height="16" viewBox="0 0 16 16"><path fill="#706e6b" d="M11.4 10l4.3 4.3a1 1 0 01-1.4 1.4L10 11.4a6.5 6.5 0 111.4-1.4zM6.5 11a4.5 4.5 0 100-9 4.5 4.5 0 000 9z"/></svg><input type="text" class="search-input" placeholder="Search..."></div>
          <button class="ask-button"><svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M8 1l1.5 3.5L13 6l-3.5 1.5L8 11l-1.5-3.5L3 6l3.5-1.5L8 1z" fill="#0176D3"/></svg><span>+ Ask</span></button>
        </div>
      </div>
      <div class="header-right">
        <button class="header-icon-btn"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#706e6b" stroke-width="1.5" fill="none"/><circle cx="12" cy="8" r="3" fill="#706e6b"/><path d="M6 18c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="#706e6b" stroke-width="1.5" fill="none"/></svg></button>
        <div class="split-button"><button class="split-btn-main"><svg width="14" height="14" viewBox="0 0 16 16"><path fill="#706e6b" d="M8 1l1.8 4.2L14 6.5l-3 3.2.7 4.8L8 12.3 4.3 14.5l.7-4.8-3-3.2 4.2-1.3L8 1z"/></svg></button><button class="split-btn-dropdown"><svg width="10" height="10" viewBox="0 0 16 16"><path fill="#706e6b" d="M4 6l4 4 4-4"/></svg></button></div>
        <button class="header-icon-btn"><svg width="24" height="24" viewBox="0 0 24 24"><path fill="#706e6b" d="M12 2a1 1 0 011 1v8h8a1 1 0 110 2h-8v8a1 1 0 11-2 0v-8H3a1 1 0 110-2h8V3a1 1 0 011-1z"/></svg></button>
        <button class="header-icon-btn"><svg width="24" height="24" viewBox="0 0 24 24"><path fill="#706e6b" d="M12 2a10 10 0 100 20 10 10 0 000-20zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg></button>
        <button class="header-icon-btn"><svg width="24" height="24" viewBox="0 0 24 24"><path fill="#706e6b" d="M20.8 13.2l-1.6-1.2c0-.3.1-.7.1-1s0-.7-.1-1l1.6-1.2c.3-.2.3-.5.2-.8l-1.5-2.6c-.2-.3-.5-.4-.8-.3l-1.9.7c-.5-.4-1.1-.7-1.7-.9L15 3.1c0-.3-.3-.6-.7-.6h-3c-.4 0-.6.3-.7.6l-.3 2c-.6.2-1.2.6-1.7.9l-1.9-.7c-.3-.1-.6 0-.8.3L4.5 8.2c-.2.3-.1.6.2.8l1.6 1.2c0 .3-.1.7-.1 1s0 .7.1 1l-1.6 1.2c-.3.2-.3.5-.2.8l1.5 2.6c.2.3.5.4.8.3l1.9-.7c.5.4 1.1.7 1.7.9l.3 2c0 .3.3.6.7.6h3c.4 0 .6-.3.7-.6l.3-2c.6-.2 1.2-.6 1.7-.9l1.9.7c.3.1.6 0 .8-.3l1.5-2.6c.1-.3 0-.6-.2-.8zM12.5 15c-1.7 0-3-1.3-3-3s1.3-3 3-3 3 1.3 3 3-1.3 3-3 3z"/></svg></button>
        <button class="header-icon-btn"><svg width="24" height="24" viewBox="0 0 24 24"><path fill="#706e6b" d="M12 2C10.3 2 9 3.3 9 5v6c0 1.7 1.3 3 3 3s3-1.3 3-3V5c0-1.7-1.3-3-3-3zm7 9h-1c0 3.5-3 6-6 6s-6-2.5-6-6H5c0 3.9 3.1 7.1 7 7.8V21h-3v1h7v-1h-3v-2.2c3.9-.7 7-3.9 7-7.8z"/></svg></button>
        <div class="avatar"><div class="avatar-circle"><svg width="24" height="24" viewBox="0 0 24 24"><circle cx="12" cy="12" r="11" fill="#032e61"/><circle cx="12" cy="9" r="3.5" fill="white"/><path d="M5.5 19.5c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5" stroke="white" stroke-width="1.5" fill="none"/></svg></div></div>
      </div>
    </header>

    <!-- Navigation -->
    <nav class="global-navigation">
      <div class="nav-tabs">
        <div class="app-name"><button class="waffle-icon"><svg width="20" height="20" viewBox="0 0 20 20"><circle cx="4" cy="4" r="2" fill="#706e6b"/><circle cx="10" cy="4" r="2" fill="#706e6b"/><circle cx="16" cy="4" r="2" fill="#706e6b"/><circle cx="4" cy="10" r="2" fill="#706e6b"/><circle cx="10" cy="10" r="2" fill="#706e6b"/><circle cx="16" cy="10" r="2" fill="#706e6b"/><circle cx="4" cy="16" r="2" fill="#706e6b"/><circle cx="10" cy="16" r="2" fill="#706e6b"/><circle cx="16" cy="16" r="2" fill="#706e6b"/></svg></button><span class="app-name-text">Sales</span></div>
        <a href="#" class="nav-tab">Home</a>
        <a href="#" class="nav-tab has-dropdown">Accounts <svg width="10" height="10" viewBox="0 0 16 16"><path fill="#706e6b" d="M4 6l4 4 4-4"/></svg></a>
        <a href="#" class="nav-tab has-dropdown">Contacts <svg width="10" height="10" viewBox="0 0 16 16"><path fill="#706e6b" d="M4 6l4 4 4-4"/></svg></a>
        <a href="#" class="nav-tab has-dropdown">Opportunities <svg width="10" height="10" viewBox="0 0 16 16"><path fill="#706e6b" d="M4 6l4 4 4-4"/></svg></a>
        <a href="#" class="nav-tab has-dropdown">Leads <svg width="10" height="10" viewBox="0 0 16 16"><path fill="#706e6b" d="M4 6l4 4 4-4"/></svg></a>
        <a href="#" class="nav-tab has-dropdown">Campaigns <svg width="10" height="10" viewBox="0 0 16 16"><path fill="#706e6b" d="M4 6l4 4 4-4"/></svg></a>
        <a href="#" class="nav-tab active">*Ask: Partner Cloud Setup <span class="tab-close">&times;</span></a>
      </div>
      <button class="edit-btn"><svg width="16" height="16" viewBox="0 0 16 16"><path fill="#706e6b" d="M11.7 1.3l3 3L5 14H2v-3l9.7-9.7zm-1.4 4.4L4 12v1h1l6.3-6.3-1-1z"/></svg></button>
    </nav>

    <!-- Main content with sidebar -->
    <div style="display: flex; flex: 1; overflow: hidden; background: #f3f3f3;">
      <!-- Left Sidebar -->
      <aside class="setup-sidebar">
        <div class="setup-sidebar-search">
          <svg width="20" height="20" viewBox="0 0 16 16"><path fill="#706e6b" d="M11.4 10l4.3 4.3a1 1 0 01-1.4 1.4L10 11.4a6.5 6.5 0 111.4-1.4zM6.5 11a4.5 4.5 0 100-9 4.5 4.5 0 000 9z"/></svg>
          <input type="text" class="setup-sidebar-input" placeholder="Quick Find">
        </div>
        <a href="#" class="setup-tree-home">Setup Home</a>
        <div class="setup-tree-section">
          <span class="setup-tree-heading">ADMINISTRATION</span>
          <a href="#" class="setup-tree-item"><svg width="8" height="8" viewBox="0 0 16 16"><path fill="#706e6b" d="M6 4l4 4-4 4"/></svg> Users</a>
          <a href="#" class="setup-tree-item"><svg width="8" height="8" viewBox="0 0 16 16"><path fill="#706e6b" d="M6 4l4 4-4 4"/></svg> Data</a>
          <a href="#" class="setup-tree-item"><svg width="8" height="8" viewBox="0 0 16 16"><path fill="#706e6b" d="M6 4l4 4-4 4"/></svg> Email</a>
        </div>
        <div class="setup-tree-section">
          <span class="setup-tree-heading">PLATFORM TOOLS</span>
          <a href="#" class="setup-tree-item"><svg width="8" height="8" viewBox="0 0 16 16"><path fill="#706e6b" d="M6 4l4 4-4 4"/></svg> Apps</a>
          <a href="#" class="setup-tree-item"><svg width="8" height="8" viewBox="0 0 16 16"><path fill="#706e6b" d="M6 4l4 4-4 4"/></svg> Feature Settings</a>
          <a href="#" class="setup-tree-item"><svg width="8" height="8" viewBox="0 0 16 16"><path fill="#706e6b" d="M6 4l4 4-4 4"/></svg> Slack</a>
          <a href="#" class="setup-tree-item"><svg width="8" height="8" viewBox="0 0 16 16"><path fill="#706e6b" d="M6 4l4 4-4 4"/></svg> Heroku</a>
          <a href="#" class="setup-tree-item"><svg width="8" height="8" viewBox="0 0 16 16"><path fill="#706e6b" d="M6 4l4 4-4 4"/></svg> MuleSoft</a>
          <a href="#" class="setup-tree-item"><svg width="8" height="8" viewBox="0 0 16 16"><path fill="#706e6b" d="M6 4l4 4-4 4"/></svg> Einstein</a>
          <a href="#" class="setup-tree-item setup-tree-item--active">Partner Ecosystem Configuration</a>
        </div>
      </aside>

      <!-- Conversation -->
      <main class="convo-main" style="border-left: 1px solid #aeaeae;">
        <div class="convo-title-bar">
          <div class="convo-title"><svg width="14" height="14" viewBox="0 0 16 16"><path fill="#0176D3" d="M8 1l1.5 3.5L13 6l-3.5 1.5L8 11l-1.5-3.5L3 6l3.5-1.5L8 1z"/></svg><span>Configuring Partner Experience</span></div>
          <button class="end-session-btn">End Session</button>
        </div>

      <div class="convo-thread">
        <!-- User message -->
        <div class="user-bubble animate-in" style="justify-content: flex-end; display: flex;">
          <p style="max-width: 70%; background: #edf4ff; border-radius: 20px 20px 4px 20px; padding: 12px 18px; font-size: 13px; color: #03234d; line-height: 18px;">Help me set up my Partner Selling Environment and the related features</p>
        </div>

        <!-- Thinking dots (visible briefly) -->
        <div class="thinking-dots-container" id="thinkingDots">
          <div class="agent-header">
            <svg class="sparkle" width="16" height="16" viewBox="0 0 16 16"><path fill="#7c3aed" d="M8 1l1.5 3.5L13 6l-3.5 1.5L8 11l-1.5-3.5L3 6l3.5-1.5L8 1z"/></svg>
            <span class="agent-name">Agentforce</span>
          </div>
          <div class="thinking-dots"><span></span><span></span><span></span></div>
        </div>

        <!-- Agent response (fades in after thinking) -->
        <div class="agent-response agent-content" id="agentResponse">
          <div class="agent-header">
            <svg class="sparkle" width="16" height="16" viewBox="0 0 16 16"><path fill="#7c3aed" d="M8 1l1.5 3.5L13 6l-3.5 1.5L8 11l-1.5-3.5L3 6l3.5-1.5L8 1z"/></svg>
            <span class="agent-name">Agentforce</span>
          </div>
          <p>Let me search for features related to "Partner Selling Environment" in your organization.</p>

          <div style="display: flex; flex-direction: column; gap: 0px; padding: 8px 0;">
            <div class="search-status">
              <svg width="16" height="16" viewBox="0 0 16 16" style="width: 32px;"><path fill="#706e6b" d="M11.4 10l4.3 4.3a1 1 0 01-1.4 1.4L10 11.4a6.5 6.5 0 111.4-1.4zM6.5 11a4.5 4.5 0 100-9 4.5 4.5 0 000 9z"/></svg>
              <span>Searching 'Partner Cloud' in Salesforce</span>
              <span class="search-status-count">14 sources</span>
            </div>
            <div class="search-status">
              <svg width="16" height="16" viewBox="0 0 16 16" style="width: 32px;"><path fill="#706e6b" d="M11.4 10l4.3 4.3a1 1 0 01-1.4 1.4L10 11.4a6.5 6.5 0 111.4-1.4zM6.5 11a4.5 4.5 0 100-9 4.5 4.5 0 000 9z"/></svg>
              <span>Searching 'Partner Selling' in Salesforce</span>
              <span class="search-status-count">12 sources</span>
            </div>
          </div>

          <p class="features-heading">Features to Set Up</p>
          <p style="font-size: 13px; color: #5c5c5c; margin-bottom: 8px;">There are 6 features that are awaiting being set up.</p>

          <div class="feature-item">
            <p class="feature-name">Define your Deal Rules</p>
            <p class="feature-desc">These rules determine which leads can be qualified.</p>
          </div>
          <div class="feature-item">
            <p class="feature-name">Setup your loyalty tiers</p>
            <p class="feature-desc">Establish reward levels and perks to incentivize and retain your best customers.</p>
          </div>
          <div class="feature-item">
            <p class="feature-name">Customise your Agentforce</p>
            <p class="feature-desc">Configure your AI agents to best support your partners and team.</p>
          </div>
          <div class="feature-item">
            <p class="feature-name">Create your first training track</p>
            <p class="feature-desc">Build a structured learning path to effectively onboard new team members or upskill your partners.</p>
          </div>
          <div class="feature-item">
            <p class="feature-name">Launch a referral program</p>
            <p class="feature-desc">Design a system of incentives to encourage your existing customers to bring in new business.</p>
          </div>
          <div class="feature-item">
            <p class="feature-name">Set commission rules</p>
            <p class="feature-desc">Define the payout structures, targets, and percentages for your sales team's closed deals.</p>
          </div>

          <p style="margin-top: 14px;">I can help you set these up here or you can do them via the Partner Cloud Setup Widget.</p>
        </div>
      </div>

      <!-- Input bar with gradient -->
      <div style="position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 800px; max-width: 100%; padding: 0 32px;">
        <div style="position: relative; height: 150px; background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,1) 16.83%); pointer-events: none;"></div>
        <div class="convo-input-area" style="position: relative; padding-bottom: 8px;">
          <div class="convo-input-wrapper">
            <div class="convo-input-box">
              <textarea class="convo-input-text" placeholder="Follow up..." rows="1"></textarea>
              <div class="convo-input-toolbar">
                <div class="convo-input-actions">
                  <button class="input-action-btn"><svg width="16" height="16" viewBox="0 0 16 16"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" fill="none" stroke-width="1.2"/><rect x="4" y="4" width="3" height="3" fill="currentColor"/><rect x="9" y="4" width="3" height="3" fill="currentColor"/><rect x="4" y="9" width="3" height="3" fill="currentColor"/></svg></button>
                </div>
                <div class="convo-input-actions">
                  <button class="input-action-btn"><svg width="16" height="16" viewBox="0 0 16 16"><path d="M1 12l4-10 4 7 3-4 3 7H1z" fill="none" stroke="currentColor" stroke-width="1.2"/></svg></button>
                </div>
              </div>
            </div>
          </div>
          <!-- Connections -->
          <div class="convo-connections-bar">
            <span class="connections-label">Connections</span>
            <div class="connection-icon"><svg width="12" height="12" viewBox="0 0 16 16"><path fill="#0176D3" d="M8 1C6.3 1 5 2.3 5 4v3c0 1.7 1.3 3 3 3s3-1.3 3-3V4c0-1.7-1.3-3-3-3z"/></svg></div>
            <div class="connection-icon"><svg width="12" height="12" viewBox="0 0 16 16"><circle cx="8" cy="8" r="6" fill="#706e6b"/></svg></div>
            <div class="connection-icon"><svg width="12" height="12" viewBox="0 0 16 16"><path fill="#d4a017" d="M8 2l2 4 4 1-3 3 1 4-4-2-4 2 1-4-3-3 4-1z"/></svg></div>
            <span class="convo-disclaimer">Generative AI can produce inaccurate responses. Review responses carefully.</span>
            <a href="#" class="feedback-link">Share feedback</a>
          </div>
        </div>
      </div>
      </main>
    </div>

    <!-- Footer -->
    <footer class="global-footer global-footer--ask">
      <div class="footer-left">
        <div class="footer-dropdown">
          <label class="footer-label">Version</label>
          <select class="footer-select" onchange="if(this.value==='v1') window.location.href='../v1-index.html'; if(this.value==='v2') window.location.href='../v2/index.html'; if(this.value==='v3') window.location.href='../v3/index.html'; if(this.value==='v4') window.location.href='../v4/index.html';"><option value="v5" selected>V5 - Enhanced Setup Hub v2</option><option value="v4">V4 - Enhanced Setup Hub</option><option value="v1">V1 - Conversational Setup</option><option value="v2">V2 - Partner Feature Setup Hub</option><option value="v3">V3 - Slack + MCP Assistant</option></select>
        </div>
        <div class="footer-dropdown">
          <label class="footer-label">Journey</label>
          <select class="footer-select"><option value="setup" selected>Setup Journey</option><option value="30days">30 Days Later</option></select>
        </div>
      </div>
      <div class="footer-center"><span class="footer-updated">Last updated: June 3, 2026</span></div>
      <div class="footer-right">
        <div class="footer-nav">
          <button class="footer-nav-btn" id="prevBtn" title="Previous screen"><svg width="16" height="16" viewBox="0 0 16 16"><path fill="currentColor" d="M10.7 3.3L6 8l4.7 4.7-1.4 1.4L3.2 8l6.1-6.1 1.4 1.4z"/></svg><span>Prev</span></button>
          <span class="footer-screen-indicator">Screen 2 / 8</span>
          <button class="footer-nav-btn" id="nextBtn" title="Next screen"><span>Next</span><svg width="16" height="16" viewBox="0 0 16 16"><path fill="currentColor" d="M5.3 12.7L10 8 5.3 3.3l1.4-1.4L12.8 8l-6.1 6.1-1.4-1.4z"/></svg></button>
        </div>
      </div>
    </footer>
  </div>

  <script>
    const screens = ['screen-3.html','screen-4.html','screen-5.html','screen-7.html','screen-8.html','screen-9.html','screen-6.html','screen-10.html'];
    let currentScreen = 1;
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    function updateNavButtons() {
      prevBtn.disabled = currentScreen === 0;
      nextBtn.disabled = currentScreen === screens.length - 1;
      document.querySelector('.footer-screen-indicator').textContent = `Screen ${currentScreen + 1} / ${screens.length}`;
    }
    prevBtn.addEventListener('click', () => { if (currentScreen > 0) { currentScreen--; window.location.href = screens[currentScreen]; }});
    nextBtn.addEventListener('click', () => { if (currentScreen < screens.length - 1) { currentScreen++; window.location.href = screens[currentScreen]; }});
    document.addEventListener('keydown', (e) => { if (e.key === 'ArrowLeft' && !prevBtn.disabled) prevBtn.click(); else if (e.key === 'ArrowRight' && !nextBtn.disabled) nextBtn.click(); });
    updateNavButtons();

    // Hide thinking dots and show response after delay
    setTimeout(() => {
      document.getElementById('thinkingDots').classList.add('hide');
    }, 2000);
  </script>
</body>
</html>
